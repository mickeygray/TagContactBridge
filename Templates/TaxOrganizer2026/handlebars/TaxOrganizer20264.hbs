<!-- tax-04-last-call.hbs -->
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Last Call to File Your 2025 Return</title>
  </head>
  <body
    style="font-family: Arial, sans-serif; line-height: 1.6; color: #333; padding: 20px;"
  >
    <table
      style="max-width:600px; width:100%; margin:auto; border-collapse: collapse;"
    >
      <tr>
        <td style="padding: 20px; border: 1px solid #ddd;">

          <img
            src="cid:emailHeader"
            width="600"
            style="display:block;width:100%;max-width:600px;height:auto;"
            alt="Last Call"
          />

          <h2 style="color: #2a7ae2;">Hi {{name}},</h2>

          <h3>Last call: we need to hear from you to file your 2025 return on
            time.</h3>

          <p>
            We’re in the final stretch of tax season. If we haven’t heard from
            you yet, we can’t complete your
            <strong>2025 return</strong>
            without your organizer and documents.
          </p>

          <p><strong>Please send these items right away:</strong></p>

          <table
            role="presentation"
            cellpadding="0"
            cellspacing="0"
            border="0"
            style="width:100%; border-collapse:collapse;"
          >
            <tr>
              <th
                align="left"
                style="padding:8px 10px; border-bottom:1px solid #e5e5e5; font-size:14px;"
              >Document</th>
              <th
                align="left"
                style="padding:8px 10px; border-bottom:1px solid #e5e5e5; font-size:14px;"
              >Where to find it</th>
            </tr>

            <tr>
              <td style="padding:8px 10px; border-bottom:1px solid #f0f0f0;">W-2
                / 1099 income forms</td>
              <td
                style="padding:8px 10px; border-bottom:1px solid #f0f0f0;"
              >Employer + payer portals/mail</td>
            </tr>

            <tr>
              <td
                style="padding:8px 10px; border-bottom:1px solid #f0f0f0;"
              >Brokerage 1099 / 1099-B (if applicable)</td>
              <td
                style="padding:8px 10px; border-bottom:1px solid #f0f0f0;"
              >Brokerage portal</td>
            </tr>

            <tr>
              <td
                style="padding:8px 10px; border-bottom:1px solid #f0f0f0;"
              >Mortgage interest (1098) + property taxes</td>
              <td
                style="padding:8px 10px; border-bottom:1px solid #f0f0f0;"
              >Lender/county portals</td>
            </tr>

            <tr>
              <td
                style="padding:8px 10px; border-bottom:1px solid #f0f0f0;"
              >Estimated tax payments (if paid)</td>
              <td style="padding:8px 10px; border-bottom:1px solid #f0f0f0;">IRS
                account + bank statements</td>
            </tr>

            <tr>
              <td style="padding:8px 10px;">Completed organizer + best contact
                time</td>
              <td style="padding:8px 10px;">Use the attached organizer; include
                your preferred callback time</td>
            </tr>
          </table>

          <p style="margin-top: 16px;">
            If you want our help, you need to start today—otherwise your filing
            may be delayed.
          </p>

          <p style="margin-top: 20px; font-weight: bold;">
            Call us now at
            <a
              href="tel:+1 {{phone}}"
              style="color: #2a7ae2; text-decoration: none;"
            >{{phone}}</a>
            and send documents to
            {{processingEmail}}.
          </p>

          <div style="margin-top: 30px;">
            {{{signature}}}
          </div>

        </td>
      </tr>
    </table>
  </body>
</html>