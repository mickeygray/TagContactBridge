<!-- tax-01-welcome-prospect.hbs -->
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Welcome to Tax Season</title>
  </head>
  <body
    style="font-family: Arial, sans-serif; line-height: 1.6; color: #333; padding: 20px;"
  >
    <table
      style="max-width:600px; width:100%; margin:auto; border-collapse: collapse;"
    >
      <tr>
        <td style="padding: 20px; border: 1px solid #ddd;">

          <img
            src="cid:emailHeader"
            width="600"
            style="display:block;width:100%;max-width:600px;height:auto;"
            alt="Tax Season"
          />

          <h2 style="color: #2a7ae2;">Hi {{name}},</h2>

          <h3>Tax season is here — and 2025 is in the books.</h3>

          <p>
            If you haven’t filed yet (or you want help making sure your return
            is accurate and complete), our team is available to walk you through
            what you’ll need and help you get organized.
          </p>

          <p>
            You can learn more or get started here:
            <a
              href="https://www.wynntaxsolutions.com"
              style="color: #2a7ae2; text-decoration: none; font-weight: bold;"
            >wynntaxsolutions.com</a>
          </p>

          <p>
            If you’d like to speak with someone today, give us a call and we’ll
            help you map out next steps. The earlier we start, the easier it is
            to file on time.
          </p>

          <p style="margin-top: 20px; font-weight: bold;">
            Call us at
            <a
              href="tel:+1 {{phone}}"
              style="color: #2a7ae2; text-decoration: none;"
            >{{phone}}</a>
            and we’ll get you taken care of.
          </p>

          <div style="margin-top: 30px;">
            {{{signature}}}
          </div>

        </td>
      </tr>
    </table>
  </body>
</html>