{
  "name": "tagcontactbridge",
  "version": "2.0.0",
  "description": "Multi-brand tax resolution platform — lead intake, cadence, agent monitoring, client marketing",
  "main": "clientBridge/server.js",
  "scripts": {
    "leadbridge": "node leadBridge/server.js",
    "clientbridge": "node clientBridge/server.js",
    "ringbridge": "node ringBridge/server.js",

    "dev": "concurrently --names \"LEAD:4000,CLIENT:5000,RING:6000\" -c \"green,cyan,yellow\" \"npm run leadbridge\" \"npm run clientbridge\" \"npm run ringbridge\"",
    "dev:debug": "concurrently --names \"LEAD:4000,CLIENT:5000,RING:6000\" -c \"green,cyan,yellow\" \"npm run leadbridge:debug\" \"npm run clientbridge:debug\" \"npm run ringbridge:debug\"",

    "leadbridge:debug": "nodemon leadBridge/server.js",
    "clientbridge:debug": "nodemon clientBridge/server.js",
    "ringbridge:debug": "nodemon ringBridge/server.js",

    "client": "npm start --prefix clientBridge/client",
    "client:build": "npm run build --prefix clientBridge/client",
    "client:install": "npm install --prefix clientBridge/client",

    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop all",
    "pm2:restart": "pm2 restart all",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status",

    "postinstall": "npm install --prefix clientBridge/client"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@ringcentral/sdk": "^5.0.6",
    "axios": "^1.10.0",
    "bcryptjs": "^3.0.2",
    "body-parser": "^2.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "form-data": "^4.0.2",
    "handlebars": "^4.7.8",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.13.0",
    "multer": "^1.4.5-lts.2",
    "neverbounce": "^5.0.5",
    "node-cron": "^3.0.3",
    "node-ssh": "^13.2.1",
    "node-stream-zip": "^1.15.0",
    "nodemailer": "^6.10.1",
    "openai": "^6.27.0",
    "p-limit": "^6.2.0",
    "papaparse": "^5.5.2",
    "ssh2-sftp-client": "^12.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.9"
  }
}
